    "rt-client": "https://github.com/Azure-Samples/aoai-realtime-audio-sdk/releases/download/js/v0.5.0/rt-client-0.5.0.tgz",
    "sass": "^1.83.2",
    "spark-md5": "^3.0.2",
    "use-debounce": "^10.0.4",
    "zod": "^3.24.2",
    "zustand": "^5.0.3",
    "bufferutil": "^4.0.9",
    "utf-8-validate": "^6.0.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
